{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SkillBasin",
  "version": "0.1.2",
  "identifier": "dev.skillbasin.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SkillBasin",
        "width": 1056,
        "height": 748,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/Sayicon/skill-basin/releases/latest/download/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4Qzk0QzY0NTc4OEMxNEIKUldSTHdZaFhaRXpKU0Y1NEJaemNMZDRiTVhDZkxSVnZVdCsrSzRlbGhGTnF1T0xJTE8yQzB0WW4K",
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
